<nav id="controls" aria-label="Slide controls">
  <button class="btn" id="btnStart" title="First slide (Home)">|◀</button>
  <button class="btn" id="btnPrev" title="Previous (←)">◀ Prev</button>
  <span id="counter">1 / 15</span>
  <button class="btn" id="btnNext" title="Next (→)">Next ▶</button>
  <button class="btn" id="btnEnd" title="Last slide (End)">▶|</button>
  <button class="btn" id="btnNotes" title="Toggle presenter notes (P)">Notes: ON</button>
  <button class="btn" id="btnFull" title="Fullscreen (F)">⛶ Full</button>
</nav>

<script>
(function(){
  const slides=[...document.querySelectorAll('.slide')];
  const counter=document.getElementById('counter');
  const bar=document.getElementById('progress');
  let i=0;

  function show(n){
    i=Math.max(0,Math.min(slides.length-1,n));
    slides.forEach((s,k)=>s.classList.toggle('active',k===i));
    counter.textContent=(i+1)+' / '+slides.length;
    bar.style.width=((i+1)/slides.length*100)+'%';
    if(history.replaceState) history.replaceState(null,'','#'+(i+1));
    document.getElementById('btnPrev').disabled=(i===0);
    document.getElementById('btnNext').disabled=(i===slides.length-1);
  }
  const next=()=>show(i+1), prev=()=>show(i-1);

  document.getElementById('btnNext').onclick=next;
  document.getElementById('btnPrev').onclick=prev;
  document.getElementById('btnStart').onclick=()=>show(0);
  document.getElementById('btnEnd').onclick=()=>show(slides.length-1);

  // presenter notes toggle
  const btnNotes=document.getElementById('btnNotes');
  function toggleNotes(){
    document.body.classList.toggle('clean');
    btnNotes.textContent=document.body.classList.contains('clean')?'Notes: OFF':'Notes: ON';
  }
  btnNotes.onclick=toggleNotes;

  // fullscreen
  function toggleFull(){
    if(!document.fullscreenElement) document.documentElement.requestFullscreen().catch(()=>{});
    else document.exitFullscreen();
  }
  document.getElementById('btnFull').onclick=toggleFull;

  // keyboard
  document.addEventListener('keydown',e=>{
    if(e.key==='ArrowRight'||e.key==='PageDown'||e.key===' '){e.preventDefault();next();}
    else if(e.key==='ArrowLeft'||e.key==='PageUp'){e.preventDefault();prev();}
    else if(e.key==='Home')show(0);
    else if(e.key==='End')show(slides.length-1);
    else if(e.key==='f'||e.key==='F')toggleFull();
    else if(e.key==='p'||e.key==='P')toggleNotes();
  });

  // touch swipe
  let tx=0;
  document.addEventListener('touchstart',e=>{tx=e.changedTouches[0].clientX;},{passive:true});
  document.addEventListener('touchend',e=>{
    const dx=e.changedTouches[0].clientX-tx;
    if(Math.abs(dx)>60){dx<0?next():prev();}
  },{passive:true});

  // deep link #3
  const h=parseInt((location.hash||'').slice(1),10);
  show(isNaN(h)?0:h-1);
})();
</script>
