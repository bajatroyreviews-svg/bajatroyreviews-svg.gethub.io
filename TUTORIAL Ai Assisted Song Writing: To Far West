<style>
  :root{
    --bg1:#17100a;
    --bg2:#2b1c10;
    --parchment:#f6e8c9;
    --parchment2:#efdcb4;
    --ink:#3a2a16;
    --ink-soft:#5d452a;
    --sunset:#e8873a;
    --sunset2:#d4692a;
    --gold:#d9a84e;
    --rust:#a34d28;
    --sage:#8ba888;
    --sky:#7fb3d5;
    --shadow:0 20px 60px rgba(0,0,0,.55);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%}
  body{
    font-family:'Bitter',Georgia,serif;
    background:
      radial-gradient(1200px 600px at 80% -10%, rgba(232,135,58,.18), transparent 60%),
      radial-gradient(900px 500px at 10% 110%, rgba(163,77,40,.22), transparent 60%),
      linear-gradient(160deg,var(--bg1),var(--bg2));
    color:var(--parchment);
    overflow:hidden;
  }

  /* ===== progress bar ===== */
  #progress{position:fixed;top:0;left:0;height:6px;width:0%;z-index:60;
    background:linear-gradient(90deg,var(--sunset2),var(--gold));
    transition:width .35s ease;box-shadow:0 0 12px rgba(232,135,58,.7);}

  /* ===== slide stage ===== */
  #stage{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;padding:56px 18px 84px;}
  .slide{
    display:none;
    width:min(1120px,100%);
    max-height:100%;
    overflow-y:auto;
    background:linear-gradient(175deg,var(--parchment),var(--parchment2));
    color:var(--ink);
    border-radius:18px;
    border:3px solid var(--gold);
    outline:2px solid rgba(58,42,22,.35);
    outline-offset:-9px;
    box-shadow:var(--shadow);
    padding:clamp(26px,4vw,56px);
    animation:fadeUp .45s ease;
    scrollbar-width:thin;
  }
  .slide.active{display:block}
  @keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:none}}

  /* ===== typography ===== */
  .kicker{font-size:clamp(.8rem,1.4vw,1rem);letter-spacing:.28em;text-transform:uppercase;
    color:var(--rust);font-weight:800;margin-bottom:.6em}
  h1{font-family:'Rye',serif;font-weight:400;font-size:clamp(2rem,5vw,3.6rem);line-height:1.12;color:var(--ink);margin-bottom:.35em}
  h2{font-family:'Rye',serif;font-weight:400;font-size:clamp(1.6rem,3.6vw,2.6rem);line-height:1.15;color:var(--ink);margin-bottom:.4em}
  h3{font-size:clamp(1.15rem,2.2vw,1.5rem);color:var(--rust);margin:1em 0 .4em;font-weight:800}
  p,li{font-size:clamp(1.05rem,1.9vw,1.3rem);line-height:1.55;color:var(--ink-soft)}
  p{margin-bottom:.8em}
  ul{margin:.4em 0 1em 1.3em}
  li{margin-bottom:.45em}
  strong{color:var(--ink)}
  .lead{font-size:clamp(1.2rem,2.3vw,1.5rem);color:var(--ink)}
  .center{text-align:center}

  /* ===== badges & chips ===== */
  .phase-badge{display:inline-block;background:var(--rust);color:var(--parchment);
    font-weight:800;letter-spacing:.12em;text-transform:uppercase;
    font-size:clamp(.75rem,1.3vw,.95rem);padding:.45em 1em;border-radius:999px;margin-bottom:1em;
    box-shadow:0 3px 0 rgba(58,42,22,.35)}
  .chips{display:flex;flex-wrap:wrap;gap:.5em;margin:.6em 0 1em}
  .chip{background:rgba(163,77,40,.12);border:2px solid var(--rust);color:var(--rust);
    padding:.3em .85em;border-radius:999px;font-weight:600;font-size:clamp(.9rem,1.6vw,1.1rem)}

  /* ===== presenter notes (Troy's script) ===== */
  .note{
    margin-top:1.4em;border-left:6px solid var(--sunset2);
    background:rgba(232,135,58,.13);
    padding:1em 1.2em;border-radius:0 12px 12px 0;
  }
  .note .tag{display:block;font-size:.8em;letter-spacing:.2em;text-transform:uppercase;
    font-weight:800;color:var(--sunset2);margin-bottom:.5em}
  .note p{font-style:italic;color:#6b4a26;margin-bottom:.4em}
  body.clean .note{display:none}


  /* ===== lyric poster & lyrics ===== */
  .poster-wrap{text-align:center;margin:1em auto}
  .poster-img{max-height:56vh;max-width:100%;border:4px solid var(--gold);border-radius:12px;box-shadow:0 10px 30px rgba(58,42,22,.35)}
  .poster-cap{margin-top:.7em;font-size:.95em;color:var(--ink-soft);font-style:italic}
  .lyrics{columns:2;column-gap:2.5em;margin-top:.5em}
  .stanza{break-inside:avoid;margin-bottom:1.1em}
  .stanza h4{font-size:.95em;letter-spacing:.22em;color:var(--rust);font-weight:800;margin-bottom:.45em}
  .stanza p{font-size:clamp(1rem,1.6vw,1.15rem);line-height:1.5;margin:0;color:var(--ink-soft)}
  .stanza.chorus p{font-style:italic}
  @media (max-width:700px){.lyrics{columns:1}}
  /* ===== wanted poster / title card ===== */
  .poster{ text-align:center; }
  .poster .rule{width:120px;height:4px;background:var(--rust);margin:1.1em auto;border-radius:2px}
  .poster .byline{font-size:clamp(1.15rem,2.4vw,1.6rem);color:var(--ink);font-weight:600}
  .poster .aka{display:inline-block;margin-top:.7em;padding:.4em 1.2em;border:3px double var(--rust);
    border-radius:10px;font-family:'Rye',serif;font-size:clamp(1.2rem,2.6vw,1.8rem);color:var(--rust);background:rgba(217,168,78,.15)}
  .poster .song{margin-top:1.4em;font-size:clamp(1.05rem,2vw,1.35rem);color:var(--ink-soft)}
  .poster .song em{font-weight:800;color:var(--rust)}

  /* ===== media slots ===== */
  .media-frame{margin:1.2em auto;border:4px solid var(--gold);border-radius:14px;overflow:hidden;
    box-shadow:0 10px 30px rgba(58,42,22,.3);background:#20140b;max-width:760px}
  .media-frame svg{display:block;width:100%;height:auto}
  .slot{margin:1.2em auto;max-width:760px;border:3px dashed var(--rust);border-radius:14px;
    padding:1.6em;text-align:center;background:rgba(163,77,40,.07)}
  .slot p{color:var(--rust);font-weight:600;margin:0}
  .slot .small{font-size:.95em;font-weight:400;color:var(--ink-soft);margin-top:.5em}

  /* ===== video embed ===== */
  .video-frame{margin:1.2em auto;max-width:840px;border:4px solid var(--gold);border-radius:14px;overflow:hidden;box-shadow:0 10px 30px rgba(58,42,22,.3);background:#20140b}
  .video-frame .ratio{position:relative;width:100%;aspect-ratio:16/9}
  .video-frame iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
  .watch-row{text-align:center;margin-top:.9em}
  .watch-link{display:inline-block;color:var(--rust);font-weight:600;font-size:clamp(1rem,1.8vw,1.15rem);text-decoration:none;border-bottom:2px solid var(--rust);padding-bottom:2px}
  .pull{font-size:clamp(1.3rem,2.6vw,1.75rem);font-style:italic;color:var(--rust);font-weight:600;line-height:1.4;margin:1em 0;text-align:center}

  /* ===== soundscape table ===== */
  table{width:100%;border-collapse:collapse;margin:1em 0;font-size:clamp(.95rem,1.7vw,1.15rem)}
  th{background:var(--rust);color:var(--parchment);text-align:left;padding:.7em .9em;font-size:1em;letter-spacing:.05em}
  td{padding:.7em .9em;border-bottom:2px solid rgba(163,77,40,.25);vertical-align:top;color:var(--ink-soft)}
  tr:nth-child(even) td{background:rgba(217,168,78,.14)}
  td:first-child{font-weight:800;color:var(--ink)}

  /* ===== loop diagram ===== */
  .loop{display:flex;flex-wrap:wrap;gap:.7em;align-items:center;justify-content:center;margin:1.2em 0}
  .loop .step{background:var(--ink);color:var(--parchment);padding:.7em 1.1em;border-radius:12px;
    font-weight:600;font-size:clamp(.95rem,1.8vw,1.15rem);box-shadow:0 4px 0 rgba(0,0,0,.25)}
  .loop .arrow{color:var(--rust);font-weight:800;font-size:1.4em}

  /* ===== script scenes ===== */
  .scene-head{display:flex;align-items:baseline;gap:.8em;flex-wrap:wrap}
  .scene-num{background:var(--ink);color:var(--gold);font-family:'Rye',serif;font-size:clamp(1.1rem,2.2vw,1.5rem);
    padding:.15em .6em;border-radius:10px}
  .visual{background:rgba(127,179,213,.16);border-left:6px solid var(--sky);
    padding:.9em 1.1em;border-radius:0 12px 12px 0;margin:1em 0}
  .visual .tag{display:block;font-size:.8em;letter-spacing:.2em;text-transform:uppercase;font-weight:800;color:#3f6d8e;margin-bottom:.4em}
  .visual p{font-style:italic;color:#41607a;margin:0}
  .line{margin:.8em 0;padding-left:1em;border-left:4px solid rgba(163,77,40,.3)}
  .line .who{font-weight:800;color:var(--rust)}
  .line.gemini .who{color:#3f6d8e}
  .line p{margin:0}

  /* ===== controls ===== */
  #controls{position:fixed;left:0;right:0;bottom:0;z-index:50;display:flex;align-items:center;justify-content:center;gap:10px;
    padding:14px;background:linear-gradient(0deg,rgba(23,16,10,.95),rgba(23,16,10,0));}
  .btn{cursor:pointer;border:2px solid var(--gold);background:rgba(58,42,22,.85);color:var(--parchment);
    font-family:'Bitter',serif;font-weight:600;font-size:1rem;padding:.55em 1.1em;border-radius:999px;
    transition:transform .12s ease,background .12s ease}
  .btn:hover{background:var(--rust);transform:translateY(-2px)}
  .btn:focus-visible{outline:3px solid var(--sunset);outline-offset:2px}
  #counter{min-width:86px;text-align:center;font-weight:600;color:var(--gold);font-size:1rem}
  .hint{position:fixed;top:14px;right:16px;z-index:50;font-size:.85rem;color:rgba(246,232,201,.55);text-align:right;line-height:1.5}

  @media (max-width:640px){
    .hint{display:none}
    #stage{padding:40px 10px 90px}
    .btn{font-size:.92rem;padding:.5em .85em}
  }
</style>
</head>
